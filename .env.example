# Email Configuration (required)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
RECIPIENT_EMAIL=contact@scintechn.com

# OpenRouter (required for the Spark scoping endpoint /api/spark).
# Get a key at https://openrouter.ai/. Server-side only — never exposed to the client.
OPENROUTER_API_KEY=

# Rate-limiting and Spark daily-budget counter (optional — both fall back to
# in-memory state when omitted; in-memory is fine on a single warm instance
# but does not survive cold starts on serverless).
# Set both to enable Upstash Redis backing for /api/contact, /api/spark, and
# the Spark daily $-cap counter.
# Provision a free database at https://upstash.com and copy the REST URL/token.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
