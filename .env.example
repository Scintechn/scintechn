# Email Configuration (required)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
RECIPIENT_EMAIL=contact@scintechn.com

# Rate-limiting (optional — falls back to in-memory Map when omitted)
# Set both to enable Upstash Redis distributed rate-limiting on /api/contact.
# Provision a free database at https://upstash.com and copy the REST URL/token.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
